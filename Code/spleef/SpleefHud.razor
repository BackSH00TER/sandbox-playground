@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent

<root>
    @if (!string.IsNullOrEmpty(Text))
    {
        <div class="countdown">@Text</div>
    }
</root>

<style>
    .countdown {
        position: absolute;
        top: 20%;
        left: 0;
        right: 0;
        text-align: center;
        font-family: Poppins;
        font-size: 240px;
        font-weight: 900;
        color: white;
        text-shadow: 0px 4px 20px rgba(0, 0, 0, 0.8);
    }
</style>

@code {
    public string Text { get; private set; } = string.Empty;

    protected override void OnUpdate()
    {
        Text = GameState.Current?.DisplayText ?? string.Empty;
    }

    protected override int BuildHash() => System.HashCode.Combine(Text);
}
